{
  "name": "clubhouse-scheduler",
  "version": "0.1.0",
  "description": "Mobile-first HOA clubhouse scheduler (React + Hono on a single Cloudflare Worker, backed by D1).",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "npm run build && vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply clubhouse_scheduler --local",
    "db:migrate:staging": "wrangler d1 migrations apply clubhouse_scheduler_staging --env staging --remote",
    "db:migrate:production": "wrangler d1 migrations apply clubhouse_scheduler_production --env production --remote",
    "db:seed:local": "wrangler d1 execute clubhouse_scheduler --local --file=./scripts/seed.sql",
    "deploy:staging": "npm run build && wrangler deploy --env staging",
    "deploy:production": "npm run build && wrangler deploy --env production"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "hono": "^4.9.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.7.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.7.0",
    "@cloudflare/vitest-pool-workers": "^0.9.0",
    "@eslint/js": "^9.33.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.20.0"
  }
}
